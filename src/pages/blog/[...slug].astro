---
// src/pages/blog/[...slug].astro
import { queryWordPress } from "../../lib/wordpress";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

Astro.response.headers.set(
	"Cache-Control",
	"public, s-maxage=120, stale-while-revalidate=30",
);

export async function getStaticPaths() {
	const SLUGS_QUERY = `
   query MainBlog {
  posts(first: 100) {
    nodes {
      title
      slug
      excerpt
      date
      featuredImage {
        node {
          imgThumbnail: sourceUrl(size: THUMBNAIL)
          imgMedium: sourceUrl(size: MEDIUM)
          imgMediumLarge: sourceUrl(size: MEDIUM_LARGE)
          imgLarge: sourceUrl(size: LARGE)
          imgFull: sourceUrl
        }
      }
      categories {
        nodes {
          id
          slug
        }
      }

    }
  }
}`;
	const response = await queryWordPress(SLUGS_QUERY);
	const nodes = response?.data?.posts?.nodes || response?.posts?.nodes || [];

	return nodes.map((post: any) => ({
		params: { slug: post.slug },
	}));
}

const { slug } = Astro.params;

// Sanitize the slug to strip out trailing/leading slashes from the catch-all parameter route
const cleanSlug = slug ? slug.replace(/^\/|\/$/g, "") : "";

const DATA_QUERY = `
query GetPostAndRecent($id: ID!) {
  post(id: $id, idType: SLUG) {
    title
    content
    excerpt
     featuredImage {
        node {
          imgThumbnail: sourceUrl(size: THUMBNAIL)
          imgMedium: sourceUrl(size: MEDIUM)
          imgMediumLarge: sourceUrl(size: MEDIUM_LARGE)
          imgLarge: sourceUrl(size: LARGE)
          imgFull: sourceUrl
        }
      }
  }
  posts(first: 3) {
    nodes {
      slug
      title
      date
      excerpt
      featuredImage {
        node {
          mediaItemUrl
        }
      }
    }
  }
}`;

const response = await queryWordPress(DATA_QUERY, { id: cleanSlug });
const post = response?.data?.post || response?.post;
const recentBlogs =
	response?.data?.posts?.nodes || response?.posts?.nodes || [];

if (!post) {
	return Astro.redirect("/404");
}

const cleanDescription = post.excerpt
	? post.excerpt.replace(/<[^>]*>?/gm, "").trim()
	: "";

const bannerUrl =
	post.featuredImage?.node?.imgMediumLarge || "/blog-3.webp";
---

<html lang="en">
	<head>
		<BaseHead title={post.title} description={cleanDescription} />
		<link rel="preload" as="image" href={bannerUrl} />
	</head>
	<body>
		<Header />

		<section class="banner-sec banner-radius">
			<div class="banner-space"></div>
			<div class="container">
				<div class="row align-items-center">
					<div class="col-lg-6">
						<div class="project-image">
							<img
								src={bannerUrl || "/blog-1.png"}
								alt={post.title || "Blog Banner"}
								width="776"
								height="776"
								fetchpriority="high"
							/>
						</div>
					</div>
					<div class="col-lg-6">
						<div class="title-data">
							<h1 class="fs-60">
								{post.title}
							</h1>
							<p>
								{cleanDescription}
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="contenetblog-sec section-padding">
			<div class="container">
				<div class="heding-popup">
					<div class="menu-icon popup">
						<svg class="bars" viewBox="0 0 100 100">
							<path
								class="line top"
								d="m 30,33 h 40 c 13.100415,0 14.380204,31.80258 6.899646,33.421777 -24.612039,5.327373 9.016154,-52.337577 -12.75751,-30.563913 l -28.284272,28.284272"
							></path>
							<path
								class="line middle"
								d="m 70,50 c 0,0 -32.213436,0 -40,0 -7.786564,0 -6.428571,-4.640244 -6.428571,-8.571429 0,-5.895471 6.073743,-11.783399 12.286435,-5.570707 6.212692,6.212692 28.284272,28.284272 28.284272,28.284272"
							></path>
							<path
								class="line bottom"
								d="m 69.575405,67.073826 h -40 c -13.100415,0 -14.380204,-31.80258 -6.899646,-33.421777 24.612039,-5.327373 -9.016154,52.337577 12.75751,30.563913 l 28.284272,-28.284272"
							></path>
						</svg>
					</div>
					<ul class="listheaidng"></ul>
				</div>

				<div
					class="content-holders"
					set:html={post?.content || "error"}
				/>
			</div>
		</section>

		<Footer />

		<style is:global>
			.title-data {
				max-width: 95%;
				margin-left: auto;
			}
			.project-image img {
				border-radius: 10px;
				overflow: hidden;
			}
			.content-holders h1,
			.content-holders h2,
			.content-holders h3,
			.content-holders h4,
			.content-holders h5,
			.content-holders h6 {
				margin: revert;
				padding: revert;
			}
				.content-holders p{
					/* margin: revert; */
					padding: revert;
					padding-bottom: 10px;

				}
			.content-holders ul,
			.content-holders ol {
				padding: 10px 0px 10px 20px;
			}
			.content-holders a {
				text-decoration: underline;
			}
			.content-holders ul li {
				list-style: disc;
			}
			.content-holders ol li{
		    list-style: auto;
			}
			.menu-icon.popup {
				position: fixed;
				background: var(--color-blue);
				bottom: 3%;
				left: 1%;
				z-index: 9999;
			}

			ul.listheaidng li a {
				font-size: 16px;
				font-weight: 400;
				background: var(--color-blue);
				display: block;
				color: var(--color-white);
				padding: 10px;
				border-radius: 5px;
				line-height: 130%;
				margin-bottom: 5px;
			}
			ul.listheaidng {
				position: fixed;
				bottom: 11%;
				left: 1%;
				display: flex; /* Keep it flex so your layout works */
				flex-direction: column;
				gap: 4px;
				background: #f5f5f0;
				padding: 10px;
				border-radius: 10px;
				width: 300px;
				z-index: 9999;

				/* Smooth transition settings */
				opacity: 0;
				visibility: hidden;
				clip-path: polygon(0 100%, 100% 100%, 100% 100%, 0% 100%);
				transition:
					clip-path 0.3s linear,
					opacity 0.3s linear,
					visibility 0.3s linear;
			}

			.heding-popup.active ul.listheaidng {
				display: flex; /* Maintain flex layout when active */
				opacity: 1;
				visibility: visible;
				clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
			}
			.menu-icon.popup .bars .line {
				stroke: var(--color-white);
			}
			@media (max-width: 991px) {
				.project-image {
					padding-bottom: 30px;
				}
				.title-data {
					max-width: 100%;
				}
			}
			@media (max-width: 767px) {
				ul.listheaidng li a {
					font-size: 12px;
				}
				ul.listheaidng {
					width: 200px;
				}
				.menu-icon.popup {
					bottom: 1%;
				}
			}
		</style>

		<script>
			const initShare = () => {
				const shareBtns =
					document.querySelectorAll(".native-share-btn");
				shareBtns.forEach((btn) => {
					btn.addEventListener("click", async (e) => {
						e.preventDefault();
						const title = btn.getAttribute("data-title");
						const relativeUrl = btn.getAttribute("data-url");
						const url = relativeUrl
							? window.location.origin + relativeUrl
							: window.location.href;

						if (navigator.share) {
							try {
								await navigator.share({
									title: title,
									text: `Check out this article: ${title}`,
									url: url,
								});
							} catch (err: any) {
								if (err.name !== "AbortError")
									console.error("Error sharing:", err);
							}
						} else {
							try {
								await navigator.clipboard.writeText(url);
								alert("Link copied to clipboard!");
							} catch (err) {
								console.error("Failed to copy: ", err);
							}
						}
					});
				});
			};

			const initToc = () => {
				const contentHolder =
					document.querySelector(".content-holders");
				const tocList = document.querySelector(".listheaidng");

				// Ensure elements exist on the page before executing
				if (!contentHolder || !tocList) return;

				// Clear any existing list items (crucial for view transition swaps)
				tocList.innerHTML = "";

				// Find all h2 tags inside your dynamic wordpress content
				const h2s = contentHolder.querySelectorAll("h2");

				h2s.forEach((h2, index) => {
					const id = `title-${index + 1}`;
					h2.id = id; // Dynamically injects the ID attribute to the H2 tag

					// Create the structural elements <li><a href="#id">Text</a></li>
					const li = document.createElement("li");
					const a = document.createElement("a");
					a.href = `#${id}`;
					a.textContent = h2.textContent || h2.innerText;

					li.appendChild(a);
					tocList.appendChild(li);
				});
			};

			// Execute on initial layout load
			initShare();
			initToc();

			// Re-run scripts if Astro View Transitions swap the page content
			document.addEventListener("astro:after-swap", () => {
				initShare();
				initToc();
			});

			const initMenuPopup = () => {
				const menuIcon = document.querySelector(".menu-icon.popup");

				if (!menuIcon) return;

				menuIcon.addEventListener("click", function () {
					// Find the closest parent with the class .heding-popup
					const parentHeader = this.closest(".heding-popup");
					if (parentHeader) {
						parentHeader.classList.toggle("active");
					}

					// Toggles active on the SVG bars inside for your path animation
					const svgBars = this.querySelector(".bars");
					if (svgBars) {
						svgBars.classList.toggle("active");
					}
				});
			};

			// Execute on load
			initMenuPopup();

			// Re-run if you are using Astro View Transitions
			document.addEventListener("astro:after-swap", initMenuPopup);
		</script>
	</body>
</html>
