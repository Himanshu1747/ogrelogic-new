                border-radius: 50%;
                z-index: -1;
                right: -26%;
                top: 14%;
                /* animation */
                animation: pulseCircle 2s infinite;
            }

            /* outer ripple effect */
            .circle-design::after {
                content: "";
                position: absolute;
                width: 100%;
                height: 100%;
                border-radius: 50%;
                top: 0;
                left: 0;
                background: rgba(229, 227, 253, 0.6);
                animation: ripple 2s infinite;
