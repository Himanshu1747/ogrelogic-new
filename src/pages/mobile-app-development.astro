---
import BaseHead from "../components/BaseHead.astro";
import Faq from "../components/Faq.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { queryWordPress } from "../lib/wordpress.js";

// Set Cache Headers for CDN/Vercel/Netlify performance
Astro.response.headers.set(
    "Cache-Control",
    "public, s-maxage=120, stale-while-revalidate=30",
);

// 1. Queries (Kept your logic, cleaned up whitespace)
const MOBILEPAGE_QUERY = `
query Mobiledevelopment {
  page(id: "/mobile-app-development", idType: URI) {
    seo { canonical cornerstone focuskw fullHead }
    title
    content
    featuredImage { node { sourceUrl altText mediaDetails { width height } } }
    mobileapp {
      storefrontTitle storefrontContent storefrontLinks { title url }
      websiteApp { appDoesTitle appLists { applistDetails } websiteappImage { node { mediaItemUrl mediaDetails { height width } } } }
      growthGrid { growthTitle growthDesc }
      workTitle workDesc workGrid { workgridImage { node { mediaItemUrl } } workIcon { node { mediaItemUrl } } workSubtitle worksubtitleDes workLists { listWorks } }
      workwithCta { title url }
      industryTitle industryDesc industryImage{ node{ sourceUrl } } industryDetails{ industryName industryIntro }
      weworkTitle weworkDesc weworkGrid{ weworkIcon{ node{ sourceUrl } } weworkMainTitle weworkMainDesc }
      miniTitle storiesTitle storiesDesc
      testimonialGrids{ clientName clientReviews clientImage{ node{ sourceUrl } } }
      faqTitle faqDesc faqGrids{ questionTitile answerFaq }
          featuredTitle
      featuredWorkIntro
    }
  }
}`;

const PORTFOLIO_QUERY = `
query GetPortfolioData {
  portfolios(first: 20) {
    nodes {
      title
      slug
      featuredImage { node { sourceUrl altText } }
      excerpt
      portfolioCategories { nodes { slug } }
      portfoliomain {
        toLive
        catTypes { typesName }
        projcetUrl {
          liveUrl { title url target }
          techImage { node { sourceUrl } }
        }
      }
    }
  }
}`;

// Fetch queries in parallel for speed
const [pageRes, portfolioRes] = await Promise.all([
    queryWordPress(MOBILEPAGE_QUERY),
    queryWordPress(PORTFOLIO_QUERY),
]);

// 2. Data Mapping (Cleaning up hard-coded "error" fallbacks)
const finaldata = pageRes?.data?.page;
const seodata = finaldata?.seo;
const appData = finaldata?.mobileapp;

const allPortfolios = portfolioRes?.data?.portfolios?.nodes || [];

// Filter and Slice in one pass
const displayedNodes = allPortfolios
    .filter((node) =>
        node.portfolioCategories?.nodes?.some(
            (cat) => cat.slug === "mobile-app",
        ),
    )
    .slice(0, 3);
