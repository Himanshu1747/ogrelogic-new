---
// D:\2026\may\new-ogrelogic\src\pages\our-work\[...slug].astro
import { queryWordPress } from "../../lib/wordpress";
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=120, stale-while-revalidate=30",
);

export async function getStaticPaths() {
  const SLUGS_QUERY = `
    query GetPortfolioSlugs {
      portfolios(first: 100) {
        nodes {
          slug
        }
      }
    }`;
  const response = await queryWordPress(SLUGS_QUERY);

  // FIX 1: Access .data property
  const nodes = response?.data?.portfolios?.nodes || [];

  return nodes.map((item: any) => ({
    params: { slug: item.slug },
  }));
}

const { slug } = Astro.params;

const DATA_QUERY = `
query GetPortfolioDetail($id: ID!) {
  portfolio(id: $id, idType: SLUG) {
    title
    content
    excerpt
    featuredImage {
      node {
        sourceUrl
      }
    }
    portfolioCategories {
      nodes {
        name
        slug
      }
    }
  }
  portfolios(first: 3) {
    nodes {
      slug
      title
      excerpt
      featuredImage {
        node {
          sourceUrl
        }
      }
    }
  }
}`;

const response = await queryWordPress(DATA_QUERY, { id: slug });

// FIX 2: Access .data for both the main item and the recent work
const item = response?.data?.portfolio;
const recentWork = response?.data?.portfolios?.nodes || [];

// If the item doesn't exist in WordPress, redirect to 404
if (!item) {
  return Astro.redirect("/404");
}

const cleanDescription = item.excerpt
  ? item.excerpt.replace(/<[^>]*>?/gm, "").trim()
  : "Discover our latest portfolio project.";

const bannerUrl = item.featuredImage?.node?.sourceUrl || "/fallback.jpg";
