        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--color-blue);
      }
      .two-up {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 32px;
      }
      .two-up,
      .table-wrap,
      .ai-stats,
      .revenue-grid {
        padding-top: 60px;
      }

      .chart-card {
        background: var(--color-f5f5f0);
        padding: 48px;
        position: relative;
        border-radius: 10px;
      }

      .chart-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 20px;
        margin-bottom: 40px;
        padding-bottom: 30px;
        border-bottom: 1px solid #d5c8b6;
      }

      .chart-jump {
        text-align: right;
        flex-shrink: 0;
      }

      .chart-jump .lbl {
        text-transform: uppercase;
        letter-spacing: 2px;
        /* font-size: 11px; */
        color: #756b58;
        margin-top: 8px;
      }

      .chart-card svg {
        display: block;
        width: 100%;
        height: auto;
      }
      .kw-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--color-f5f5f0);
        border: 1px solid var(--color-f5f5f0);
        overflow: hidden;
      }

      .kw-table thead th {
        padding: 20px 24px;
        /* font-family: "JetBrains Mono", monospace; */
        font-size: 18px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: var(--color-black);
        border-bottom: 1px solid var(--color-f5f5f0);
        font-weight: 600;
      }

      .kw-table tbody td {
        padding: 18px 24px;
        border-bottom: 1px solid rgba(213, 200, 182, 0.45);
        text-transform: capitalize;
        font-size: 18px;
      }

      .kw-table tbody tr:last-child td {
        border-bottom: none;
      }

      .kw-table tbody tr {
        transition: background 0.3s ease;
      }

      .kw-table tbody tr:hover {
        background: rgba(213, 200, 182, 0.15);
      }

      .kw-table .kw {
        font-weight: 500;
        /* color: var(--color-blue); */
      }

      .kw-table .c {
        text-align: center;
      }

      .kw-table .r {
        text-align: right;
      }

      .kw-table .before,
      .kw-table .after {
        text-align: center;
      }

      .pos-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 42px;
        height: 42px;
        padding: 0 12px;
        border-radius: 999px;
        background: #e6ddd0;
        color: #3b3328;
        font-weight: 600;
        font-size: 14px;
      }

      .pos-pill.top {
        background: var(--color-blue);
        color: var(--color-white);
      }

      .pos-pill.new {
        background: var(--color-orange);
        color: #fff;
      }

      .delta {
        text-align: right;
        color: #3d5a40;
        font-weight: 500;
        white-space: nowrap;
      }

      .delta.big {
        color: var(--color-orange);
        font-weight: 600;
      }

      .ai-stats {
        display: grid;
        grid-template-columns: 1.4fr 0.8fr;
        gap: 40px;
      }

      .ai-bars,
      .ai-big {
        background: var(--color-f5f5f0);
        border-radius: 10px;
        /* border: 1px solid #d5c8b6; */
        padding: 40px;
      }

      .ai-bars h4 {
        font-size: var(--fs-35);
        font-weight: 500;
        margin-bottom: 35px;
      }

      .ai-bar-row {
        display: grid;
        grid-template-columns: 110px 1fr 60px;
        gap: 18px;
        align-items: center;
        margin-bottom: 30px;
      }

      .ai-bar-row .name {
        font-family: "DM Sans", sans-serif;
        font-weight: 500;
        color: #0b2145;
      }

      .bar-wrap {
        height: 14px;
        background: rgba(213, 200, 182, 0.4);
        border-radius: 50px;
        overflow: hidden;
      }

      .bar-fill {
        height: 100%;
        border-radius: 50px;
        background: linear-gradient(
          90deg,
          var(--color-orange) 0%,
          #f59a56 100%
        );
      }

      .ai-bar-row .v {
        text-align: right;

        font-size: 14px;
        color: #756b58;
      }

      .ai-note {
        margin-top: 30px;
        padding-top: 25px;
        border-top: 1px solid #d5c8b6;

        font-size: 18px;
        font-style: italic;
        color: #756b58;
        line-height: 1.6;
      }

      .ai-note strong {
        color: var(--color-orange);
        font-weight: 500;
      }

      .ai-big {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 35px;
      }

      .ai-big .row-data {
        padding-bottom: 10px;
        border-bottom: 1px solid rgba(213, 200, 182, 0.5);
      }

      .ai-big .row-data:last-child {
        border-bottom: none;
        padding-bottom: 0;
      }

      .big-num {
        font-size: var(--fs-60);
        font-weight: 800;
        line-height: 1;
        color: var(--color-orange);
        margin-bottom: 8px;
      }

      .bootmdata-ai {
        padding-top: 20px;
      }
      .revenue-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }

      .revenue-grid .cell {
        background: var(--color-f5f5f0);
        border: 1px solid #d5c8b6;
        padding: 36px;
        position: relative;
        transition: all 0.3s ease;
      }

      .revenue-grid .cell:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);
      }

      .revenue-grid .lbl {
        font-size: 12px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #756b58;
        margin-bottom: 18px;
      }

      .revenue-grid .big {
        font-size: var(--fs-60);
        line-height: 0.95;
        color: var(--color-black);
        font-weight: 500;
        margin-bottom: 16px;
      }

      .revenue-grid .big span {
        color: #756b58 !important;
        font-size: 0.55em;
      }

      .revenue-grid .yoy {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--color-orange);
        font-family: "DM Sans", sans-serif;
        font-size: 16px;
        font-weight: 600;
      }

      .revenue-grid .cell::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 4px;
        height: 100%;
        background: var(--color-orange);
      }

      .chart-card.single {
        margin-top: 60px;
      }
      .work-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        border-top: 1px solid var(--rule);
        margin-top: 40px;
      }

      .work-item {
        display: grid;
        grid-template-columns: 70px 1fr;
        gap: 24px;
        padding: 40px 0;
        border-bottom: 1px solid var(--rule);
      }

      .work-item:nth-child(odd) {
        padding-right: 40px;
      }

      .work-item:nth-child(even) {
        padding-left: 40px;
        border-left: 1px solid var(--rule);
      }

      .work-item .num {
        font-size: var(--fs-35);
        line-height: 1;
        font-weight: 600;
        font-style: italic;
        color: var(--color-orange);
      }

      .work-item h3,
      .work-item h4 {
        color: var(--color-black);
        margin-bottom: 12px;
        font-weight: 500;
      }

      .work-item ul {
        padding-top: 30px;
      }

      .work-item ul li {
        position: relative;
        padding-left: 10px;
        font-weight: 400;
        font-size: 18px;
        padding-bottom: 10px;
      }

      .work-item ul li::before {
        content: "";
        position: absolute;
        left: 0;
        top: 40%;
        width: 8px;
        height: 2px;
        transform: translate(-50%, -50%);
        background: var(--color-orange);
      }

      .work-grid {
        border-top: 1px solid #c9bfa8;
      }

      .work-item {
        border-bottom: 1px solid #c9bfa8;
      }

      .work-item:nth-child(even) {
        border-left: 1px solid #c9bfa8;
      }
      @media (max-width: 1600px) {
        .project-image {
          height: 492px;
        }
        .objective-data p,
        .soluion-data p {
          font-size: 15px;
        }
      }
      @media (max-width: 1400px) {
        .client-image {
          max-width: 350px;
        }
        .objective-data {
          min-height: 225px;
        }
        .custom-button {
          padding-top: 40px;
        }
        .gridsolutin {
          max-width: 100%;
        }
      }
      @media (max-width: 1199px) {
        .center-mobile-data {
          max-width: 400px;
          width: 100%;
          margin: 0 auto 30px;
        }
        .sliderobjevctive-holders,
        .grid-businessimpact {
          padding-top: 30px;
        }
      }
      @media (max-width: 991px) {
        .project-image {
          height: auto;
          margin-bottom: 30px;
        }
        .grid-button {
          padding-top: 10px;
        }
        .overview-data {
          max-width: 100%;
        }
        .soluion-data {
          padding: 10px;
        }
        .business-grow {
          padding: 15px;
        }
        .kw-table {
          display: block;
          overflow-x: auto;
        }

        .kw-table th,
        .kw-table td {
          white-space: nowrap;
        }
      }
      @media (max-width: 767px) {
        .gridsolutin,
        .grid-businessimpact {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 20px;
        }
        .title-data {
          max-width: 100%;
        }
        .client-image {
          margin: 0 auto;
          padding-top: 30px;
        }
      }
      @media (max-width: 575px) {
      }
    </style>
  </body>
</html>
