        <Footer />

        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const filterLinks =
                    document.querySelectorAll(".filter-lists li a");
                const workItems = Array.from(
                    document.querySelectorAll(".works-holderss"),
                );
                const loadMoreBtn = document.getElementById("loadMoreBtn");

                const ITEMS_PER_PAGE = 6;
                let currentVisibleLimit = ITEMS_PER_PAGE;
                let currentActiveFilter = "all";

                function updateGrid() {
                    let matchingItems = [];
                    workItems.forEach((item) => {
                        const itemCategories =
                            item.getAttribute("data-categories") || "";
                        const htmlItem = item as HTMLElement;

                        if (
                            currentActiveFilter === "all" ||
                            itemCategories
                                .toLowerCase()
                                .includes(currentActiveFilter)
                        ) {
                            matchingItems.push(htmlItem);
                        } else {
                            htmlItem.style.display = "none";
                        }
                    });

                    matchingItems.forEach((item, index) => {
                        item.style.display =
                            index < currentVisibleLimit ? "" : "none";
                    });

                    if (loadMoreBtn) {
                        loadMoreBtn.style.display =
                            matchingItems.length > currentVisibleLimit
                                ? "inline-block"
                                : "none";
                    }
                }

                filterLinks.forEach((link) => {
                    link.addEventListener("click", (e) => {
                        e.preventDefault();
                        const target = e.currentTarget as HTMLElement;
                        document
                            .querySelectorAll(".filter-lists li")
                            .forEach((li) => li.classList.remove("active"));
                        target.parentElement?.classList.add("active");
                        currentActiveFilter =
                            target.getAttribute("data-filter")?.toLowerCase() ||
                            "all";
                        currentVisibleLimit = ITEMS_PER_PAGE;
                        updateGrid();
                    });
                });

                loadMoreBtn?.addEventListener("click", () => {
                    currentVisibleLimit += ITEMS_PER_PAGE;
                    updateGrid();
                });

                updateGrid();
            });
        </script>

