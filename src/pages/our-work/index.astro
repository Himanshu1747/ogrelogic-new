<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />

        {/* High Speed: Preload the LCP (Banner) Image */}
        {
            lcpImage && (
                <link
                    rel="preload"
                    as="image"
                    href={lcpImage}
                    fetchpriority="high"
                />
            )
        }

        {/* High Speed: Load Swiper CSS without blocking the main thread */}
        <link
            rel="preload"
            href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css"
            />
        </noscript>

        <BaseHead
            useYoast={true}
            canonical={finalaaldataseo?.canonical || ""}
            focuskw={finalaaldataseo?.focuskw || ""}
        />
        {
            finalaaldataseo?.fullHead && (
                <Fragment set:html={finalaaldataseo.fullHead} />
            )
        }
    </head>
