---
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { queryWordPress } from "../../lib/wordpress";

const PORTFOLIO_QUERY = `
query GetPortfolioData {
  portfolios(first: 20) {
    nodes {
      title
      slug
      featuredImage { node { sourceUrl altText } }
      excerpt
      portfolioCategories { nodes { slug } }
      portfoliomain {
        toLive
        catTypes { typesName }
        projcetUrl {
          liveUrl { title url target }
          techImage { node { sourceUrl } }
        }
      }
    }
  }
}
`;

const OURWORKSS = `
query OurWorks {
  page(id: "/our-work", idType: URI) {
    seo { canonical cornerstone focuskw fullHead }
    title
    content
    featuredImage {
      node {
        sourceUrl
        altText
        mediaDetails {
          width
          height
        }
      }
    }
    ourWorks{
      portfolioTitle
      portfolioDesc
    }
  }
}
`;

// Optimization: Fetching both queries in parallel to reduce server response time
const [portfolioRes, pageRes] = await Promise.all([
    queryWordPress(PORTFOLIO_QUERY),
    queryWordPress(OURWORKSS),
]);

const allNodes = portfolioRes?.data?.portfolios?.nodes || [];
const displayedNodes = allNodes;

const finalaaldata = pageRes?.data?.page;
const finalaaldataseo = pageRes?.data?.page?.seo;

// Preload the Featured Image URL if it exists
const lcpImage = finalaaldata?.featuredImage?.node?.sourceUrl;
