        <script is:inline>
            // Optimized FAQ Logic - Using original tags/classes
            class FaqWrapper extends HTMLElement {
                connectedCallback() {
                    const holders = this.querySelectorAll(".faq-holders");
                    const loadMoreBtn = this.querySelector(
                        ".loadmore-button .link-button",
                    );
                    const container = this.querySelector(".faq-container");
                    let currentVisible = 4;

                    // 1. Accordion Toggle Logic
                    container?.addEventListener("click", (e) => {
                        const header = e.target.closest(".grid-faq");
                        if (!header) return;

                        const content = header.nextElementSibling;
                        const isActive = header.classList.contains("active");

                        // Close others
                        this.querySelectorAll(".grid-faq").forEach((h) =>
                            h.classList.remove("active"),
                        );
                        this.querySelectorAll(".bootm-data").forEach((c) =>
                            c.classList.remove("active"),
                        );

                        if (!isActive) {
                            header.classList.add("active");
                            content.classList.add("active");
                        }
                    });

                    // 2. Load More Logic
                    const updateVisibility = () => {
                        holders.forEach(
                            (h, i) =>
                                (h.style.display =
                                    i < currentVisible ? "" : "none"),
                        );
                        if (currentVisible >= holders.length && loadMoreBtn) {
                            loadMoreBtn.closest(
                                ".loadmore-button",
                            ).style.display = "none";
                        }
                    };

                    loadMoreBtn?.addEventListener("click", (e) => {
                        e.preventDefault();
                        currentVisible += 4;
                        updateVisibility();
                    });

                    updateVisibility();
                }
            }
            if (!customElements.get("faq-wrapper"))
                customElements.define("faq-wrapper", FaqWrapper);
        </script>
