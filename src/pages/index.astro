			src="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.js"
			defer></script>
		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				/* ---------------- HELPERS ---------------- */
				const runWhenIdle = (cb) => {
					if ("requestIdleCallback" in window) {
						requestIdleCallback(cb, { timeout: 2000 });
					} else {
						setTimeout(cb, 300);
					}
				};

				const runOnVisible = (el, cb, rootMargin = "0px") => {
					if (!el) return;
					const obs = new IntersectionObserver(
						(entries, observer) => {
							if (entries[0].isIntersecting) {
								cb();
								observer.disconnect();
							}
						},
						{ rootMargin },
					);
					obs.observe(el);
				};

				/* ---------------- VIDEO LAZY LOAD 🚨 ---------------- */
				const video = document.querySelector(".banner-video");

				if (video) {
					const loadVideo = () => {
						if (video.querySelector("source")) return;

						const source = document.createElement("source");
						source.src = video.dataset.src;
						source.type = "video/mp4";
						video.appendChild(source);

						video.load();
						video.play().catch(() => {});
					};

					runOnVisible(video, loadVideo, "300px");
				}

				/* ---------------- MARQUEE ---------------- */
				const tracks = document.querySelectorAll(".marquee-track");

				tracks.forEach((track) => {
					let pos = 0;
					const speed = 1.2;
					let width = track.scrollWidth;
					let rafId;

					track.style.willChange = "transform";

					const updateWidth = () => (width = track.scrollWidth);

					window.addEventListener(
						"resize",
						() => {
							clearTimeout(track._resizeTimer);
							track._resizeTimer = setTimeout(updateWidth, 200);
						},
						{ passive: true },
					);

					const animate = () => {
						pos -= speed;
						if (Math.abs(pos) > width / 2) pos = 0;
						track.style.transform = `translate3d(${pos}px,0,0)`;
						rafId = requestAnimationFrame(animate);
					};

					runOnVisible(
						track,
						() => {
							rafId = requestAnimationFrame(animate);
						},
						"200px",
					);

					// pause when tab inactive
					document.addEventListener("visibilitychange", () => {
						if (document.hidden) cancelAnimationFrame(rafId);
						else rafId = requestAnimationFrame(animate);
					});
				});

				/* ---------------- SWIPER ---------------- */
				const swiperEl = document.querySelector(".homeSwiperating");

				runOnVisible(
					swiperEl,
					() => {
						const initSwiper = () => {
							new Swiper(".homeSwiperating", {
								slidesPerView: 2,
								spaceBetween: 10,
								loop: true,
								speed: 2500,
								autoplay: {
									delay: 0,
									disableOnInteraction: false,
								},
								allowTouchMove: false,
								freeMode: {
									enabled: true,
									momentum: false,
								},
								breakpoints: {
									576: { slidesPerView: 3 },
									768: { slidesPerView: 4 },
									992: { slidesPerView: 5 },
								},
							});
						};

						runWhenIdle(initSwiper);
					},
					"300px",
				);

				/* ---------------- SCROLL ANIMATIONS ---------------- */
				runWhenIdle(() => {
					if (window.innerWidth < 1200) return;

					const section = document.querySelector(".grid-puprose");
					if (!section) return;

					const items = section.querySelectorAll(".purpose-holders");

					items.forEach((el) => {
						el.style.opacity = "0";
						el.style.transform = "translateY(40px)";
					});

					runOnVisible(
						section,
						() => {
							items.forEach((el, i) => {
								el.animate(
									[
										{
											transform: "translateY(40px)",
											opacity: 0,
										},
										{
											transform: "translateY(0)",
											opacity: 1,
										},
									],
									{
										duration: 700,
										delay: i * 120,
										easing: "ease-out",
										fill: "forwards",
									},
								);
							});
						},
						"100px",
					);
				});
			});
		</script>

