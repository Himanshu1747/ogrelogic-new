<script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. Initialize Swiper first so we can use the instance
        const swiperThumbs = new Swiper(".mySwipervideo", {
            spaceBetween: 10,
            slidesPerView: 1,
            freeMode: true,
            watchSlidesProgress: true,
            effect: "fade",
            speed: 1000,
            allowTouchMove: false,
            fadeEffect: { crossFade: true },
        });

        const swiperMain = new Swiper(".mySwiperclient", {
            speed: 1500,
            spaceBetween: 10,
            navigation: {
                nextEl: ".swiper-button-next",
                prevEl: ".swiper-button-prev",
            },
            thumbs: { swiper: swiperThumbs },
        });

        // 2. Cache reusable elements to avoid constant DOM lookups
        const allVideos = document.querySelectorAll(".client-video");
        const allBtns = document.querySelectorAll(".video-playbutton");

        function stopAllMedia() {
            for (let i = 0; i < allVideos.length; i++) {
                allVideos[i].pause();
                allVideos[i].currentTime = 0;
            }
            for (let j = 0; j < allBtns.length; j++) {
                allBtns[j].classList.remove("active");
            }
        }

        // 3. Use Swiper Event instead of MutationObserver (HUGE performance gain)
        swiperMain.on("slideChange", () => {
            stopAllMedia();
        });

        // 4. Delegated Click Handler (Optimized)
        document.addEventListener("click", function (e) {
            const playBtn = e.target.closest(".video-playbutton");
            if (!playBtn) return;

            const slide = playBtn.closest(".swiper-slide");
            // Only allow interaction on the active slide
            if (!slide.classList.contains("swiper-slide-active")) return;

            const video = slide.querySelector(".client-video");
            if (!video) return;

            if (video.paused) {
                // Stop others before playing this one
                stopAllMedia();
                video.play();
                playBtn.classList.add("active");
            } else {
                video.pause();
                video.currentTime = 0;
                playBtn.classList.remove("active");
            }
        });
    });
</script>