<style>
    .faq-custom-scope .faq-title {
    font-size: 25px;
    font-weight: 400;
}

.faq-custom-scope .alladat-hersss p {
    font-size: 18px;
    font-weight: 400;
}

/* FAQ Container */
.faq-custom-scope .faq-container {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-top: 50px;
}

/* Each FAQ Item */
.faq-custom-scope .faq-holders {
    overflow: hidden;
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 20px;
    border-top: 0.5px solid #d1d1d170;
    border-bottom: 0.5px solid #d1d1d170;
    padding: 20px 15px;
    background: linear-gradient(87deg, #f5f5f0, #ffffff, #f5f5f0);
}

/* Content wrapper */
.faq-custom-scope .alladat-hersss {
    max-width: 100%;
    width: 100%;
}

/* Header row */
.faq-custom-scope .grid-faq {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    cursor: pointer;
}

/* Title + icon alignment */
.faq-custom-scope .title-faq {
    display: flex;
    align-items: center;
    gap: 15px;
}

.faq-custom-scope .icon-imagess {
    max-width: 40px;
    width: 100%;
}

/* Icon wrapper */
.faq-custom-scope .faq-icon {
    max-width: fit-content;
    width: 100%;
    cursor: pointer;
}

/* Plus icon */
.faq-custom-scope span.faq-symbol {
    height: 30px;
    width: 30px;
    background: var(--color-darkblue);
    clip-path: polygon(
        45% 0%,
        55% 0%,
        55% 45%,
        100% 45%,
        100% 55%,
        55% 55%,
        55% 100%,
        45% 100%,
        45% 55%,
        0% 55%,
        0% 45%,
        45% 45%
    );
    display: block;
    transition: 0.3s ease-in;
}

/* Rotate to cross */
.faq-custom-scope .grid-faq.active span.faq-symbol {
    transform: rotate(45deg);
}

/* Hidden content */
.faq-custom-scope .bootm-data {
    overflow: hidden;
    max-height: 0;
    clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
    opacity: 0;
    transition:
        max-height 0.5s ease,
        clip-path 0.5s ease,
        opacity 0.4s ease;
}

/* Open state */
.faq-custom-scope .bootm-data.active {
    max-height: 1000px;
    clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
    opacity: 1;
}

/* Description spacing */
.faq-custom-scope .faqy-deschere {
    padding-top: 20px;
}

/* Section background */
.faq-custom-scope.faq-sec {
    background: var(--color-f5f5f0);
}

/* Load more button */
.faq-custom-scope .loadmore-button {
    max-width: fit-content;
    margin: 0 auto;
    padding-top: 50px;
}

/* Number styling */
.faq-custom-scope p.faq-no {
    font-size: 20px;
    font-weight: 800;
    color: var(--color-blue);
}

/* Responsive */
@media (max-width: 1400px) {
    .faq-custom-scope span.faq-symbol {
        height: 22px;
        width: 22px;
    }

    .faq-custom-scope .icon-imagess {
        max-width: 30px;
    }
}

@media (max-width: 767px) {
    .faq-custom-scope .icon-imagess {
        display: none;
    }
}
</style>

