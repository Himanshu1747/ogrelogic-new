<script>
  import Lenis from "lenis";
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let lenis;

  const updateLenis = (time) => {
    lenis?.raf(time * 1000);
  };

  const initLenis = () => {
    // Prevent double-initialization
    if (lenis) return;

    lenis = new Lenis({
      duration: 1.2,
      easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      touchMultiplier: 2,
      lerp: 0.1,
    });

    // Sync Lenis with GSAP ScrollTrigger globally
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add(updateLenis);
    gsap.ticker.lagSmoothing(0);
  };

  // Initialize on first load
  if (document.readyState === "complete") {
    initLenis();
  } else {
    window.addEventListener("load", initLenis, { once: true });
  }

  // Astro page transitions: Re-initialize on new page
  document.addEventListener("astro:page-load", initLenis);

  // Astro page transitions: Clean up before swapping pages
  document.addEventListener("astro:before-swap", () => {
    if (lenis) {
      gsap.ticker.remove(updateLenis);
      lenis.destroy();
      lenis = null;
    }
  });
</script>
