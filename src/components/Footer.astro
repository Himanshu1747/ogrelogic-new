---
import { queryWordPress } from "../lib/wordpress";

const COMBINED_FOOTER_QUERY = `
query GetFooterData {
  menu(id: "footer-menu", idType: SLUG) {
    menuItems(first: 100) {
      nodes {
        label
        uri
        target
      }
    }
  }
  ctaFooterWidgets
  ceoDataWidgets
  copyrightWidgets
  locationWidgets
}
`;

const response = await queryWordPress(COMBINED_FOOTER_QUERY);
const data = response?.data || {};

const finalfootermenu = data.menu?.menuItems?.nodes ?? [];
const ctaHTML = data.ctaFooterWidgets ?? "";
const ceoHTML = data.ceoDataWidgets ?? "";
const locationHTML = data.locationWidgets ?? "";
const copyrightHTML = data.copyrightWidgets ?? "";
