<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
    const container = document.querySelector(".faq-container");

    if (!container) return;

    let activeHeader = null;
    let activeContent = null;

    container.addEventListener("click", (e) => {
        const header = e.target.closest(".grid-faq");
        if (!header) return;

        const faqHolder = header.closest(".faq-holders");
        const bottomData = faqHolder.querySelector(".bootm-data");

        const isSame = header === activeHeader;

        // Remove previous active
        if (activeHeader) activeHeader.classList.remove("active");
        if (activeContent) activeContent.classList.remove("active");

        // Toggle logic
        if (!isSame) {
            header.classList.add("active");
            bottomData.classList.add("active");

            activeHeader = header;
            activeContent = bottomData;
        } else {
            activeHeader = null;
            activeContent = null;
        }
    });
});
</script>

<style>
    /* FAQ Container Wrapper */
    .faq-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .faq-holders {
        border-radius: 20px;
        overflow: hidden;
    }

    /* Accordion Header (Question) */
    .grid-faq {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        background: var(--color-white);
        border-radius: 5px;
        cursor: pointer;
        padding: 20px 30px;
    }

    .title-faq {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .icon-imagess {
        max-width: 40px;
        width: 100%;
    }

    .grid-faq .fs-30 {
        text-transform: capitalize;
    }

    /* Animated Plus/Minus Symbol */
    .faq-icon {
        max-width: fit-content;
        width: 100%;
        cursor: pointer;
    }

    span.faq-symbol {
        height: 30px;
        width: 30px;
        background: var(--color-darkblue);
        clip-path: polygon(
            45% 0%,
            55% 0%,
            55% 45%,
            100% 45%,
            100% 55%,
            55% 55%,
            55% 100%,
            45% 100%,
            45% 55%,
            0% 55%,
            0% 45%,
            45% 45%
        );
        display: block;
        transition: 0.3s ease-in;
    }

    /* Toggle States */
    .grid-faq.active span.faq-symbol {
        transform: rotate(45deg); /* Turns Plus into an X/Cross */
    }

    /* Accordion Body (Answer) */
    .bootm-data {
        background: #f6f7fa;
        overflow: hidden;
        max-height: 0;
        clip-path: polygon(0 0, 100% 0, 100% 0, 0 0);
        transition:
            clip-path 0.5s ease-in-out,
            max-height 0.5s ease-in-out,
            opacity 0.5s ease-in-out;
    }

    .bootm-data.active {
        max-height: 1000px;
        clip-path: polygon(0 0, 100% 0, 100% 100%, 0% 100%);
    }

    .faqy-deschere {
        padding: 20px 30px;
    }

    /* Responsive Styles for FAQ Items */
    @media (max-width: 1400px) {
        .grid-faq,
        .faqy-deschere {
            padding: 12px 20px;
        }
        span.faq-symbol {
            height: 22px;
            width: 22px;
        }
        .icon-imagess {
            max-width: 30px;
        }
    }

    @media (max-width: 767px) {
        .icon-imagess {
            display: none;
        }
    }
</style>