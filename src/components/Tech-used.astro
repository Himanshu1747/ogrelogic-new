<style>
    .grid-tabs {
        display: flex;
        gap: 80px;
        margin-top: 80px;
    }

    .tabs-data {
        width: 30%;
    }

    .list-tech {
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .list-tech li {
        cursor: pointer;
        font-weight: 700;
        position: relative;
        opacity: 0.5;
        transition: 0.3s;
        max-width: fit-content;
        width: 100%;
    }

    .list-tech li.active {
        opacity: 1;
        color: var(--color-blue);
    }

    .list-tech li::after {
        content: "";
        position: absolute;
        bottom: -6px;
        left: 0;
        height: 3px;
        width: 0;
        background: var(--color-blue);
        transition: 0.3s;
    }

    .list-tech li.active::after {
        width: 100%;
    }

    .techused {
        width: 70%;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 25px;
        align-items: start;
        height: fit-content;
    }

    .techused {
        position: relative;
    }

    /* BASE STATE */
    .tech-card {
        background: var(--color-white);
        padding: 20px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        gap: 20px;
        border: 1px solid #eee;

        position: absolute;
        max-width: 400px;
        width: 100%;

        opacity: 0;
        transform: translateY(30px) scale(0.96);
        visibility: hidden;
        pointer-events: none;
        cursor: pointer;

        transition:
            opacity 0.4s ease,
            transform 0.4s ease;
    }

    .tech-card.active {
        position: relative;
        opacity: 1;
        transform: translateY(0) scale(1);
        visibility: visible;
        pointer-events: auto;
    }
    .tech-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
    }

    .tech-card p {
        font-weight: 600;
    }

    .tech-image {
        max-width: 100px;
        width: 100%;
    }

