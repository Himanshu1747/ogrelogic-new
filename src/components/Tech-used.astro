<script>
    document.addEventListener("DOMContentLoaded", () => {
        const tabs = document.querySelectorAll(".list-tech li");
        const items = document.querySelectorAll(".tech-card");

        function showTech(type) {
            items.forEach((item) => {
                const tech = item.getAttribute("techtype");

                if (tech === type) {
                    item.classList.add("active");
                } else {
                    item.classList.remove("active");
                }
            });
        }

        // ✅ Default active tab + content
        const defaultTab = document.querySelector(
            '.list-tech li[data-tech="mobile"]',
        );

        tabs.forEach((t) => t.classList.remove("active")); // साफ करो
        if (defaultTab) defaultTab.classList.add("active");

        showTech("mobile");

        // Hover interaction
        tabs.forEach((tab) => {
            tab.addEventListener("mouseenter", () => {
                const type = tab.getAttribute("data-tech");

                tabs.forEach((t) => t.classList.remove("active"));
                tab.classList.add("active");

                showTech(type);
            });
        });
    });
</script>
