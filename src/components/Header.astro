---
import { queryWordPress } from "../lib/wordpress";

const COMBINED_QUERY = `
query HeaderData {
  popup: menu(id: "popup-menu", idType: SLUG) {
    menuItems(first: 100) {
      nodes { id label url uri target }
    }
  }
  main: menu(id: "main-menu", idType: SLUG) {
    menuItems(first: 100) {
      nodes { id label cssClasses url uri target }
    }
  }
  siteLogo { sourceUrl }
  socialMediaWidgets
  contactPopupWidgets
  popupLeftSidebarWidgets
}
`;

const response = await queryWordPress(COMBINED_QUERY);
const data = response?.data;

const finalmenupopup = data?.popup?.menuItems?.nodes || [];
const alldata = data?.main?.menuItems?.nodes || [];
const logomain = data?.siteLogo?.sourceUrl;

// Pre-compute the combined array on the server to save render time
const combinedMobileLinks = [...alldata, ...finalmenupopup];
