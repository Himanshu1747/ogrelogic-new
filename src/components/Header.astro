<script is:inline>
    const initScripts = () => {
        // --- 1. VANILLA MENU LOGIC ---
        const menuIcon = document.querySelector(".menu-icon");
        const popup = document.querySelector(".popup-dataholders");
        const logoMain = document.querySelector(".logo-main");
        const navHolders = document.querySelector(".main-navlinks-holders");
        const header = document.querySelector(".custom-header");
        const bars = document.querySelector(".bars");

        if (menuIcon && popup) {
            menuIcon.addEventListener("click", () => {
                popup.classList.toggle("show-popup");
                popup.style.display = "block";
                logoMain?.classList.toggle("hide-opacity");
                navHolders?.classList.toggle("hide-opacity");
                bars?.classList.toggle("active");
            });
        }

        // --- 2. VANILLA SCROLL LOGIC (THROTTLED) ---
        if (header) {
            let ticking = false;
            window.addEventListener(
                "scroll",
                () => {
                    if (!ticking) {
                        window.requestAnimationFrame(() => {
                            if (window.scrollY > 50) {
                                header.classList.add("scroll-now");
                            } else {
                                header.classList.remove("scroll-now");
                            }
                            ticking = false;
                        });
                        ticking = true;
                    }
                },
                { passive: true },
            );
        }

        // --- 3. VANILLA SMOOTH CURSOR (OPTIMIZED SLEEP STATE) ---
        const cursor = document.querySelector(".custom-cursor");
        if (cursor && window.innerWidth > 1200) {
            let mouseX = 0,
                mouseY = 0;
            let posX = 0,
                posY = 0;
            let isMoving = false;

            window.addEventListener(
                "mousemove",
                (e) => {
                    mouseX = e.clientX;
                    mouseY = e.clientY;

                    // Only start the loop if it is asleep
                    if (!isMoving) {
                        isMoving = true;
                        requestAnimationFrame(animateCursor);
                    }
                },
                { passive: true },
            );

            const animateCursor = () => {
                const distX = mouseX - posX;
                const distY = mouseY - posY;

                // If distance is significant, animate. Otherwise, go to sleep.
                if (Math.abs(distX) > 0.1 || Math.abs(distY) > 0.1) {
                    posX += distX * 0.15;
                    posY += distY * 0.15;
                    cursor.style.transform = `translate3d(${posX}px, ${posY}px, 0)`;
                    requestAnimationFrame(animateCursor);
                } else {
                    isMoving = false; // Sleep state to save CPU
                }
            };
        } else if (cursor) {
            cursor.style.display = "none";
        }
    };

    initScripts();
    document.addEventListener("astro:after-swap", initScripts);
</script>

